# ── 資料庫 ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=YourStrong!Passw0rd
DB_NAME=paulfun_blogger
DB_SSLMODE=disable

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-key-in-production
JWT_EXPIRE_HOURS=24

# ── Server ───────────────────────────────────────────────────
PORT=8080
BASE_URL=http://localhost:5266

# ── 上傳目錄 ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Storage（圖片儲存）────────────────────────────────────────
# "local" = 本地檔案系統（預設，開發用）
# "r2" = Cloudflare R2（生產環境）
STORAGE_TYPE=local

# 以下僅 STORAGE_TYPE=r2 時需要
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET=paulfun-images
# R2_PUBLIC_URL=https://img.paulfun.net
